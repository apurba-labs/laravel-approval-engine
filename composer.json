{
  "name": "apurba-labs/laravel-approval-engine",
  "description": "Batch-based approval workflow engine for Laravel",
  "keywords": [
    "laravel",
    "workflow",
    "approval-engine",
    "batch-approval",
    "multi-stage-approval",
    "enterprise-workflow",
    "approval-workflow",
    "task-automation",
    "notification-batching",
    "rbac",
    "saas-ready",
    "process-approval"
  ],
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "ApurbaLabs\\ApprovalEngine\\": "src/",
      "ApurbaLabs\\ApprovalEngine\\Database\\Seeders\\": "database/seeders/",
      "ApurbaLabs\\ApprovalEngine\\Database\\Factories\\": "database/factories/"
    }
  },
  "autoload-dev": {
    "psr-4": {
        "ApurbaLabs\\ApprovalEngine\\Tests\\": "tests/",
        "ApurbaLabs\\ApprovalEngine\\Tests\\Support\\": "tests/Support/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "ApurbaLabs\\ApprovalEngine\\ApprovalEngineServiceProvider"
      ]
    }
  },
  "require": {
    "php": "^8.1",
    "apurba-labs/laravel-iam": "@dev",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
     "orchestra/testbench": "*",
     "phpunit/phpunit": "^10.0",
    "doctrine/dbal": "^4.4"
  },
  "repositories": [
    {
      "type": "path",
      "url": "../laravel-iam",
      "options": {
          "symlink": true
      }
    }
  ]
}
